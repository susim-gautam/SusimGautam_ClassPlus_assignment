PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/custom-greetings
JWT_SECRET=change-this-to-a-long-random-string
# Same Web client ID as the React app (used to verify Google ID tokens)
GOOGLE_CLIENT_ID=
# When true (default), POST /api/auth/google-demo is allowed for local demos without OAuth
ALLOW_GOOGLE_DEMO=true
